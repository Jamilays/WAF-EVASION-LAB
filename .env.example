# ==============================================================================
# WAF Evasion Lab — environment defaults
# ------------------------------------------------------------------------------
# Copy to `.env` (already gitignored). All host ports bind to 127.0.0.1 only.
# DO NOT change that binding — this stack includes intentionally vulnerable apps.
# ==============================================================================

# ---- Traefik (single front-door for the entire matrix) ------------------
TRAEFIK_PORT=8000
TRAEFIK_DASHBOARD_PORT=8088

# ---- ModSecurity / CRS tuning -------------------------------------------
# PARANOIA 1 matches paper baseline. Raise to 4 via `--profile paranoia-high`.
MODSEC_PARANOIA=1
MODSEC_ANOMALY_INBOUND=5
MODSEC_ANOMALY_OUTBOUND=4

# ---- Shadow Daemon Postgres (internal-only) -----------------------------
SHADOWD_DB_PASSWORD=shadowd_dev_only
SHADOWD_DB_NAME=shadowd
SHADOWD_DB_USER=shadowd

# ---- DVWA MySQL (internal-only) -----------------------------------------
DVWA_DB_ROOT_PASSWORD=dvwa_root_dev_only
DVWA_DB_PASSWORD=dvwa_dev_only

# ---- Engine (Phase 3+) --------------------------------------------------
MAX_CONCURRENCY=10
# Make the engine container write results/raw as the host user so bind-mounts
# round-trip cleanly. Defaults assume a typical Linux desktop (uid 1000 gid 100
# — adjust if `id -u` / `id -g` differs).
ENGINE_UID=1000
ENGINE_GID=100

# ---- Dashboard (Phase 6, --profile dashboard) ---------------------------
# Host ports for the FastAPI backend and the React/nginx frontend. Both
# loopback-bound; the browser talks to the dashboard which proxies /api/*.
API_PORT=8001
DASHBOARD_PORT=3000

# ---- Shadow Daemon enforcement (Phase-6 audit) --------------------------
# SHADOWD_ENFORCE flips the proxy from observer to blocker. The daemon's
# own analysis requires a DB profile + HMAC-signed wire protocol (Phase 7
# work); until then the proxy's fallback pattern matcher fills the gap so
# shadowd actually blocks real attacks. Flip FALLBACK_BLOCK off to compare
# against a pure daemon-verdict implementation.
SHADOWD_ENFORCE=true
SHADOWD_FALLBACK_BLOCK=true

# ---- Engine response-snippet cap (Phase 6) ------------------------------
# Bytes of response body persisted in results/raw/<run_id>/*.json. Large
# responses (Juice Shop SQLite stack trace) benefit from a higher ceiling.
RESPONSE_SNIPPET_BYTES=65536
